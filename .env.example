# Infrastructure
NAS_IP=192.168.1.10
DOCKER_REGISTRY=${NAS_IP}:5050
DOMAIN=homelab.example.com

# GCP
GCP_PROJECT=your-gcp-project-id
GCP_PROJECT_NUMBER=000000000000
GCP_REGION=us-central1
GCS_BUCKET=garden-monitor-images
BQ_DATASET=garden_monitor
TFSTATE_BUCKET=${GCP_PROJECT}-tfstate
TFSTATE_PREFIX=garden-monitor

# Local Terraform
REPO_URL=https://github.com/youruser/garden_bot.git
NAS_NFS_PATH=/volume1/garden-minio
NAS_LANDING_PATH=/volume1/garden-landing

# 1Password (ESO references)
OP_VAULT=YourVault
OP_ITEM_MINIO=minio
OP_ITEM_POSTGRES=garden-postgres
OP_ITEM_GCP_SA=garden-gcp-sa
OP_ITEM_REPO=garden-bot-repo
